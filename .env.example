LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# 排程／管理用密鑰（例如 POST /api/broadcast/trigger-scheduled、寫入 workspaces 的 seed）
CRON_SECRET=your_cron_secret
# 設為 false 可關閉伺服器內建「每分鐘檢查排程推播」（若改由 AWS EventBridge 呼叫 API）
# BROADCAST_CRON_ENABLED=true

# 對話訊息保留設定（搭配 POST /api/conversations/cleanup）
CONVERSATION_RETENTION_DAYS=180
CONVERSATION_CLEANUP_BATCH_SIZE=400

# 選填：活動未填 liffId 時，產生活動進入網址可 fallback 至此（亦可在後台「組織與 LINE」設定預設 LIFF）
# 該 LIFF 在 LINE Developers 的 Endpoint URL 須為 https://你的網域/liff/lead（與 Messaging API 的 /webhook 不同）
LIFF_DEFAULT_ID=

# 將 .env 的 LINE 憑證寫入 Firestore `workspaces/default`（一次性，之後可改 DB 不必改部署）
# curl -X POST "https://你的網域/api/admin/line-workspace/seed-from-env" -H "X-Cron-Secret: $CRON_SECRET"
# 對話清理（建議給 Cloud Scheduler 每天呼叫一次）
# curl -X POST "https://你的網域/api/conversations/cleanup" -H "X-Cron-Secret: $CRON_SECRET"
# 排程推播（建議每分鐘呼叫一次）
# curl -X POST "https://你的網域/api/broadcast/trigger-scheduled" -H "X-Cron-Secret: $CRON_SECRET"
# 付款到期對帳（建議每天呼叫一次；過期付費訂閱降免費、清卡住的 pending 訂單）
# curl -X POST "https://你的網域/api/payment/reconcile" -H "X-Cron-Secret: $CRON_SECRET"

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Firebase Client SDK (public)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# 對外 HTTPS 原點（無尾斜線）：金流 Notify/Return 導回、圖文 Imagemap、/api/r 點擊追蹤共用
PUBLIC_BASE_URL=https://your-domain

# ── PAYUNi 統一金流 整合式支付頁 UPP（目前使用中的金流；每租戶各一組特店；server-only）──
# 沙盒申請：https://sandbox.payuni.com.tw → 會員 › 商店清單 › 串接設定 取得三把金鑰。
# 三把都設好 → paymentEnabled 才會 true（build 時計算，設好要重新 build/部署）。
# PAYUNI_ENV=test 走 sandbox-api.payuni.com.tw、prod 走 api.payuni.com.tw。
# Hash Key 固定 32 碼、IV Key 固定 16 碼（長度不符後端會直接報錯）。
PAYUNI_MERCHANT_ID=your_payuni_mer_id
PAYUNI_HASH_KEY=your_payuni_hashkey_32_chars_xxxx
PAYUNI_HASH_IV=your_ivkey_16chr
PAYUNI_ENV=test

# ── 藍新金流 MPG（舊金流，已改用 PAYUNi；程式保留但未接線）─────────────────
# 測試特店 API 用 ccore.newebpay.com、正式特店改 core.newebpay.com。
# HashKey 固定 32 碼、HashIV 固定 16 碼（長度不符後端會直接報錯）。
NEWEBPAY_MERCHANT_ID=your_newebpay_merchant_id
NEWEBPAY_HASH_KEY=your_newebpay_hashkey_32_chars_xxxx
NEWEBPAY_HASH_IV=your_hashiv_16chr
NEWEBPAY_API_URL=https://ccore.newebpay.com/MPG/mpg_gateway

# 選填：升級／加購對話框「聯繫我們」的 email 或 https 連結（未設則不顯示聯繫鈕）
# PUBLIC_SUPPORT_CONTACT=service@your-domain
