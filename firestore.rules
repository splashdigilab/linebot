rules_version = '2';

// 前端一律透過後端 API（firebase-admin）存取資料，client SDK 不直接讀寫 Firestore。
// 此 deny-all 與 myfeel（linebot-e8dda）、splash（linebot-b137e）兩專案線上版本一致；
// 任何放寬都等同把 workspaces 裡的 channelSecret / accessToken 暴露給公開的 client config。
//
// 計費 subscription（workspaces/{id}.subscription）僅由 super admin API
// （/api/admin/super/workspaces/:id）寫入。若日後放寬 workspaces 的 client 讀寫，
// subscription 與憑證欄位務必維持 server 端專屬，切勿讓 client 自行改方案／額度。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
