rules_version = '2';

// 前端一律透過後端 API（firebase-admin）存取資料，client SDK 不直接讀寫 Firestore。
// 此 deny-all 與 myfeel（linebot-e8dda）、splash（linebot-b137e）兩專案線上版本一致；
// 任何放寬都等同把 workspaces 裡的 channelSecret / accessToken 暴露給公開的 client config。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
